@model VisitesMediques.Domain.Entities.VisitaMedica

@{
    ViewData["Title"] = "Editar Visita";
}

<h1>Editar Visita Médica</h1>
<hr />

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            
            <input type="hidden" asp-for="IdVisita" />

            <div class="form-group mb-3">
                <label asp-for="NomPacient" class="control-label">Nombre del Paciente</label>
                <input asp-for="NomPacient" class="form-control" maxlength="40" required />
                <span asp-validation-for="NomPacient" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="NomMetge" class="control-label">Nombre del Médico</label>
                <input asp-for="NomMetge" class="form-control" maxlength="40" required />
                <span asp-validation-for="NomMetge" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Data" class="control-label">Fecha de la Visita</label>
                <input asp-for="Data" type="date" class="form-control" required />
                <span asp-validation-for="Data" class="text-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label asp-for="Diagnostic" class="control-label">Diagnóstico</label>
                <textarea asp-for="Diagnostic" class="form-control" maxlength="250" required></textarea>
                <span asp-validation-for="Diagnostic" class="text-danger"></span>
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Guardar Cambios</button>
                <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
            </div>
        </form>
    </div>
</div>